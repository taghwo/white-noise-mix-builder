# white-noise-mix-builder — configurable settings
#
# Copy this file to .env and the CLI will load it automatically on startup:
#
#   cp .env.example .env
#
# .env is read from the directory you run `wnm` in. Real environment variables
# take precedence over .env, so you can still override per-run:
#
#   WNM_BACKEND=silent wnm mix rain fire

# Where presets and your custom sounds live.
# Presets go in $WNM_HOME/presets, custom sounds in $WNM_HOME/sounds.
# Default: ~/.white-noise-mix
WNM_HOME=

# Force a specific audio engine instead of auto-detecting one.
# One of: ffplay | sox | afplay | silent
#   • silent  → run with no audio (handy for scripting or CI)
#   • unknown or blank → auto-detect, in order: ffplay → sox → afplay → silent
WNM_BACKEND=
